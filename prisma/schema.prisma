// See https://pris.ly/d/prisma-schema
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  hashedPassword String? // null for OAuth-only users
  cognitoSub     String?  @unique // Cognito User Pool subject (UUID) for Hosted UI auth
  isPro          Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs Job[]
  cvs  Cv[]
}

model Job {
  id          String   @id @default(cuid())
  userId      String
  sourceUrl   String?
  pastedText  String?
  rawHtml     String?
  parsedJson  Json     // {jobTitle, company, location, requiredSkills[], responsibilities[], yearsExperience, keywords[]}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvs  Cv[]

  @@index([userId])
}

model Cv {
  id               String   @id @default(cuid())
  userId           String
  jobId            String?
  fullName         String
  email            String
  phone            String
  photoBase64      String? // base64-encoded JPEG, <200 KB, 3:4 crop
  contentJson      Json     // {summary, experience: [{company,title,startDate,endDate,bullets[]}], skills[]}
  templateId       String   @default("modern")
  accentColor      String   @default("#2563eb")
  fontId           String   @default("inter")
  language         String   @default("en")
  coverLetterText  String?  // generated cover letter body text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job?  @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id        String   @id @default(cuid())
  name      String
  email     String
  rating    Int      @default(5)
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Checkout {
  id        String   @id @default(cuid())
  email     String
  amount    Float    @default(1.8)
  status    String   @default("succeeded")
  ticketId  String   @unique
  createdAt DateTime @default(now())
}

model Promo {
  id        String   @id @default("active_promo")
  code      String   @default("FREEABCV")
  updatedAt DateTime @updatedAt
}