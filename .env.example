# abCV env config — copy to .env.local and fill in real values

# Database (docker-compose exposes on 5433 to avoid local pg conflicts)
DATABASE_URL="postgresql://abcv:abcv_dev@localhost:5433/abcv?schema=public"

# App URL + secret (reserved; the own-UI flow doesn't use these, kept for back-compat)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-me"

# Cognito (own UI driving IDP APIs: signUp/confirmSignUp/initiateAuth + JWKS)
# Provision with: aws cognito-idp create-user-pool / create-user-pool-client / create-user-pool-domain
# The App Client needs --generate-secret and ALLOW_USER_PASSWORD_AUTH in explicit-auth-flows.
COGNITO_REGION="us-east-1"
COGNITO_USER_POOL_ID=""
COGNITO_CLIENT_ID=""
COGNITO_CLIENT_SECRET=""
COGNITO_DOMAIN="your-prefix.auth.us-east-1.amazoncognito.com"
COGNITO_REDIRECT_URI="http://localhost:3000/api/auth/callback/cognito"  # Hosted-UI only; unused by own-UI flow
COGNITO_LOGOUT_URI="http://localhost:3000/login"                        # Hosted-UI only; unused by own-UI flow
COGNITO_TOKEN_VALIDITY_DAYS="30"

# AWS credentials for the Cognito IDP SDK (server-side signUp/confirm/signIn).
# Any valid AWS creds work — these ops aren't IAM-gated, but the SDK needs creds to sign.
# Alternatively, use ~/.aws/credentials or an EC2/ECS instance role (default credential chain).
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# LLM — two providers, selected by LLM_PROVIDER:
#  1) "vertex" (default here): Google Vertex AI Gemini via the OpenAI-compatible
#     endpoint. Auth is an OAuth token minted from a service account key
#     (GOOGLE_APPLICATION_CREDENTIALS). Model IDs need the "google/" prefix.
LLM_PROVIDER="vertex"
LLM_MODEL="google/gemini-2.5-flash"
GOOGLE_CLOUD_PROJECT=""
VERTEX_LOCATION="global"
GOOGLE_APPLICATION_CREDENTIALS=""
#  2) "openai": any OpenAI-compatible endpoint with a static API key (NVIDIA NIM,
#     OpenAI, Groq, etc.). Set LLM_PROVIDER="openai" + LLM_API_KEYS (comma-sep).
# LLM_BASE_URL="https://integrate.api.nvidia.com/v1"
# LLM_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1"
# LLM_API_KEYS=""

# Resend (transactional email — welcome CV email)
RESEND_API_KEY=""