<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root { --accent: {{accentColor}}; --font-scale: {{fontScale}}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Inter", -apple-system, "Segoe UI", Roboto, sans-serif; color: #1f2937; line-height: 1.5; font-size: calc(10pt * var(--font-scale)); background: #fdf4ff; }
  .page { min-height: 297mm; width: 210mm; padding: 14mm 16mm 10mm; }
  .header { display: flex; align-items: center; gap: 18px; margin-bottom: 16px; }
  .photo { width: 90px; height: 120px; object-fit: cover; border-radius: 12px; border: 3px solid var(--accent); transform: rotate(-2deg); }
  .photo-placeholder { width: 90px; height: 120px; border-radius: 12px; background: #fae8ff; display: flex; align-items: center; justify-content: center; font-size: 32px; color: var(--accent); font-weight: 700; transform: rotate(-2deg); }
  .name-area h1 { font-size: 28pt; font-weight: 900; letter-spacing: -0.03em; color: #111827; }
  .name-area .role-line { font-size: 12pt; color: var(--accent); font-weight: 600; }
  .contact-row { display: flex; gap: 14px; font-size: 9pt; color: #6b7280; margin-top: 6px; }
  .section-title { font-size: 11pt; font-weight: 800; color: #fff; background: var(--accent); display: inline-block; padding: 4px 12px; border-radius: 6px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
  .summary { font-size: 10.5pt; color: #4b5563; margin-bottom: 14px; }
  .exp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .exp-card { background: #fff; border-radius: 10px; padding: 10px 12px; box-shadow: 0 2px 6px rgba(0,0,0,0.06); border-left: 4px solid var(--accent); }
  .exp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 6px; margin-bottom: 4px; }
  .exp-title { font-weight: 700; font-size: 10pt; }
  .exp-company { color: var(--accent); font-size: 9pt; font-weight: 500; }
  .exp-dates { color: #9ca3af; font-size: 8pt; white-space: nowrap; }
  .bullets { padding-left: 14px; }
  .bullets li { margin-bottom: 2px; color: #374151; font-size: 9pt; }
  .skills-wrap { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .skills-wrap span { background: #fff; color: var(--accent); padding: 3px 10px; border-radius: 20px; font-size: 9pt; font-weight: 600; border: 1px solid #f5d0fe; }
  .languages-list { list-style: none; display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .language-item { background: #fff; padding: 3px 10px; border-radius: 20px; font-size: 9pt; font-weight: 500; border: 1px solid #f5d0fe; display: flex; gap: 6px; align-items: center; }
  .lang-level { padding: 1px 6px; border-radius: 999px; font-size: 7.5pt; }
  .lang-level-high { background: var(--accent); color: #fff; }
  .lang-level-medium { background: #f3f4f6; color: #374151; }
</style>
</head>
<body>
<div class="page">
  <div class="header">
    {{#if photoB64}}<img class="photo" src="{{photoB64}}" alt="" />{{else}}<div class="photo-placeholder">{{initials}}</div>{{/if}}
    <div class="name-area">
      <h1>{{fullName}}</h1>
      {{#if roleTitle}}<div class="role-line">{{roleTitle}}</div>{{/if}}
      <div class="contact-row">
        <span>{{email}}</span>
        <span>{{phone}}</span>
      </div>
    </div>
  </div>

  <section style="margin-bottom: 14px;">
    <div class="section-title">{{uiLabels.summary}}</div>
    <p class="summary">{{content.summary}}</p>
  </section>

  <section style="margin-bottom: 14px;">
    <div class="section-title">{{uiLabels.experience}}</div>
    <div class="exp-grid">
      {{#each content.experience}}
        <div class="exp-card">
          <div class="exp-head">
            <div>
              <div class="exp-title">{{title}}</div>
              <div class="exp-company">{{company}}</div>
            </div>
            <div class="exp-dates">{{startDate}} — {{endDate}}</div>
          </div>
          <ul class="bullets">
            {{#each bullets}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/each}}
    </div>
  </section>

  <section style="margin-bottom: 14px;">
    <div class="section-title">{{uiLabels.skills}}</div>
    <div class="skills-wrap">
      {{#each content.skills}}<span>{{this}}</span>{{/each}}
    </div>
  </section>

  {{#if content.languages}}
  <section>
    <div class="section-title">{{uiLabels.languages}}</div>
    <ul class="languages-list">
      {{#each content.languages}}
        <li class="language-item">
          <span>{{this.name}}</span>
          <span class="lang-level lang-level-{{this.level}}">{{lookup ../levelLabels this.level}}</span>
        </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}
</div>
</body>
</html>
