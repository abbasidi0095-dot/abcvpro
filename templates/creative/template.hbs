<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root { --accent: {{accentColor}}; --font-scale: {{fontScale}}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Inter", -apple-system, "Segoe UI", Roboto, sans-serif; color: #1f2937; line-height: 1.5; font-size: calc(10pt * var(--font-scale)); }
  .page { min-height: 297mm; width: 210mm; }
  .header-bar {
    background: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 70%, #000));
    color: #fff; padding: 20mm 22mm 14mm;
  }
  .header-bar h1 { font-size: 30pt; font-weight: 800; letter-spacing: -0.03em; line-height: 1.1; }
  .header-bar .role-line { font-size: 12pt; font-weight: 400; opacity: 0.85; margin-top: 4px; }
  .header-bar .contact-row { display: flex; gap: 18px; margin-top: 10px; font-size: 9pt; opacity: 0.8; }
  .photo-row { display: flex; align-items: center; gap: 20px; }
  .photo { width: 80px; height: 107px; object-fit: cover; border-radius: 8px; border: 3px solid rgba(255,255,255,0.3); }
  .photo-placeholder { width: 80px; height: 107px; border-radius: 8px; border: 3px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.15); display: flex; align-items: center; justify-content: center; font-size: 28px; color: rgba(255,255,255,0.7); }
  .content { padding: 14mm 22mm 16mm; display: flex; gap: 24px; }
  .left-col { flex: 1.4; }
  .right-col { width: 140px; }
  .right-col h3 {
    font-size: 8pt; text-transform: uppercase; letter-spacing: 0.12em;
    color: var(--accent); font-weight: 600; margin-bottom: 8px; padding-bottom: 4px;
    border-bottom: 2px solid var(--accent);
  }
  .right-col ul { list-style: none; }
  .right-col li {
    font-size: 8.5pt; color: #4b5563; padding: 3px 0; border-bottom: 1px solid #f3f4f6;
  }
  .right-col li:last-child { border-bottom: none; }
  .section-title {
    font-size: 10pt; text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--accent); font-weight: 700; margin-bottom: 8px; padding-bottom: 4px;
    border-bottom: 2px solid var(--accent); display: inline-block;
  }
  .summary { font-size: 10pt; color: #4b5563; margin-bottom: 16px; }
  .exp-item { margin-bottom: 14px; }
  .exp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .exp-title { font-weight: 700; font-size: 10.5pt; color: #111827; }
  .exp-company { color: var(--accent); font-size: 9.5pt; font-weight: 500; }
  .exp-dates { color: #9ca3af; font-size: 8.5pt; white-space: nowrap; }
  .bullets { margin-top: 4px; padding-left: 16px; }
  .bullets li { margin-bottom: 3px; color: #374151; }
  .languages-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .language-item { display: flex; justify-content: space-between; align-items: center; }
  .lang-level { padding: 2px 7px; border-radius: 999px; font-size: 7.5pt; }
  .lang-level-high { background: #e5e7eb; color: #111827; }
  .lang-level-medium { background: #f3f4f6; color: #374151; }
</style>
</head>
<body>
<div class="page">
  <div class="header-bar">
    <div class="photo-row">
      {{#if photoB64}}
        <img class="photo" src="{{photoB64}}" alt="" />
      {{else}}
        <div class="photo-placeholder">{{initials}}</div>
      {{/if}}
      <div>
        <h1>{{fullName}}</h1>
        {{#if roleTitle}}<div class="role-line">{{roleTitle}}</div>{{/if}}
        <div class="contact-row">
          <span>{{email}}</span>
          <span>{{phone}}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="content">
    <div class="left-col">
      <div class="section-title">{{uiLabels.summary}}</div>
      <p class="summary">{{content.summary}}</p>

      <div class="section-title" style="margin-top: 14px;">{{uiLabels.experience}}</div>
      {{#each content.experience}}
        <div class="exp-item">
          <div class="exp-head">
            <div>
              <span class="exp-title">{{title}}</span>
              <span class="exp-company">· {{company}}</span>
            </div>
            <div class="exp-dates">{{startDate}} — {{endDate}}</div>
          </div>
          <ul class="bullets">
            {{#each bullets}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/each}}
    </div>

    <div class="right-col">
      <h3>{{uiLabels.skills}}</h3>
      <ul>
        {{#each content.skills}}<li>{{this}}</li>{{/each}}
      </ul>

      {{#if content.languages}}
      <h3>{{uiLabels.languages}}</h3>
      <ul class="languages-list">
        {{#each content.languages}}
          <li class="language-item">
            <span>{{this.name}}</span>
            <span class="lang-level lang-level-{{this.level}}">{{lookup ../levelLabels this.level}}</span>
          </li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
  </div>
</div>
</body>
</html>
