<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root { --accent: {{accentColor}}; --font-scale: {{fontScale}}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Inter", -apple-system, "Segoe UI", Roboto, sans-serif; color: #1f2937; line-height: 1.5; font-size: calc(10pt * var(--font-scale)); }
  .page { min-height: 297mm; width: 210mm; }
  .top { background: var(--accent); color: #fff; padding: 16mm 18mm 12mm; display: flex; align-items: center; gap: 18px; }
  .photo { width: 90px; height: 120px; object-fit: cover; border-radius: 6px; border: 3px solid rgba(255,255,255,0.4); }
  .photo-placeholder { width: 90px; height: 120px; border-radius: 6px; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 32px; color: rgba(255,255,255,0.9); }
  .top h1 { font-size: 28pt; font-weight: 800; letter-spacing: -0.02em; }
  .top .role-line { font-size: 12pt; opacity: 0.9; margin-top: 2px; }
  .top .contact-row { display: flex; gap: 16px; margin-top: 8px; font-size: 9pt; opacity: 0.85; }
  .content { display: flex; min-height: 0; padding: 14mm 18mm 10mm; gap: 18px; }
  .left { flex: 1.4; }
  .right { width: 130px; }
  .section-title { font-size: 10pt; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; padding-bottom: 3px; border-bottom: 2px solid var(--accent); display: inline-block; }
  .summary { font-size: 10.5pt; color: #4b5563; margin-bottom: 16px; }
  .exp-item { margin-bottom: 14px; }
  .exp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .exp-title { font-weight: 700; font-size: 11pt; }
  .exp-company { color: #6b7280; font-size: 10pt; }
  .exp-dates { color: #9ca3af; font-size: 9pt; white-space: nowrap; }
  .bullets { margin-top: 4px; padding-left: 16px; }
  .bullets li { margin-bottom: 3px; color: #374151; }
  .right h3 { font-size: 9pt; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); font-weight: 700; margin-bottom: 6px; }
  .right ul { list-style: none; }
  .right li { font-size: 9pt; color: #4b5563; padding: 3px 0; border-bottom: 1px solid #f3f4f6; }
  .right li:last-child { border-bottom: none; }
  .languages-list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
  .language-item { display: flex; justify-content: space-between; align-items: center; font-size: 8.5pt; }
  .lang-level { padding: 1px 6px; border-radius: 999px; font-size: 7.5pt; }
  .lang-level-high { background: var(--accent); color: #fff; }
  .lang-level-medium { background: #f3f4f6; color: #374151; }
</style>
</head>
<body>
<div class="page">
  <div class="top">
    {{#if photoB64}}<img class="photo" src="{{photoB64}}" alt="" />{{else}}<div class="photo-placeholder">{{initials}}</div>{{/if}}
    <div>
      <h1>{{fullName}}</h1>
      {{#if roleTitle}}<div class="role-line">{{roleTitle}}</div>{{/if}}
      <div class="contact-row">
        <span>{{email}}</span>
        <span>{{phone}}</span>
      </div>
    </div>
  </div>

  <div class="content">
    <div class="left">
      <div class="section-title">{{uiLabels.summary}}</div>
      <p class="summary">{{content.summary}}</p>

      <div class="section-title" style="margin-top: 12px;">{{uiLabels.experience}}</div>
      {{#each content.experience}}
        <div class="exp-item">
          <div class="exp-head">
            <div>
              <div class="exp-title">{{title}}</div>
              <div class="exp-company">{{company}}</div>
            </div>
            <div class="exp-dates">{{startDate}} — {{endDate}}</div>
          </div>
          <ul class="bullets">
            {{#each bullets}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/each}}
    </div>

    <div class="right">
      <h3>{{uiLabels.skills}}</h3>
      <ul>
        {{#each content.skills}}<li>{{this}}</li>{{/each}}
      </ul>

      {{#if content.languages}}
      <h3 style="margin-top: 14px;">{{uiLabels.languages}}</h3>
      <ul class="languages-list">
        {{#each content.languages}}
          <li class="language-item">
            <span>{{this.name}}</span>
            <span class="lang-level lang-level-{{this.level}}">{{lookup ../levelLabels this.level}}</span>
          </li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
  </div>
</div>
</body>
</html>
