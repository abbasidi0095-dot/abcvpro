<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root { --accent: {{accentColor}}; --font-scale: {{fontScale}}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Inter", -apple-system, "Segoe UI", Roboto, sans-serif; color: #e2e8f0; line-height: 1.5; font-size: calc(10pt * var(--font-scale)); background: #0f172a; }
  .page { display: flex; min-height: 297mm; width: 210mm; background: #0f172a; }
  .sidebar { width: 34%; background: #1e293b; padding: 18mm 10mm 10mm; border-right: 3px solid var(--accent); }
  .main { flex: 1; padding: 18mm 12mm 10mm; }
  .photo { width: 110px; height: 146px; object-fit: cover; border-radius: 8px; margin-bottom: 22px; border: 3px solid var(--accent); }
  .photo-placeholder { width: 110px; height: 146px; border-radius: 8px; margin-bottom: 22px; background: #334155; display: flex; align-items: center; justify-content: center; font-size: 48px; color: var(--accent); }
  .sidebar h2 { font-size: 9pt; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); margin-top: 18px; margin-bottom: 8px; font-weight: 700; }
  .sidebar h2:first-child { margin-top: 0; }
  .contact-info { font-size: 9.5pt; word-break: break-word; display: flex; flex-direction: column; gap: 6px; color: #cbd5e1; }
  .sidebar ul { list-style: none; display: flex; flex-wrap: wrap; gap: 6px; }
  .sidebar li { background: #334155; padding: 4px 10px; border-radius: 999px; font-size: 9pt; color: #e2e8f0; }
  .main h1 { font-size: 26pt; font-weight: 700; letter-spacing: -0.02em; color: #f8fafc; }
  .main .role-line { color: var(--accent); font-size: 12pt; margin-top: 2px; font-weight: 600; }
  .main section { margin-top: 20px; }
  .main h3 { font-size: 10.5pt; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); margin-bottom: 10px; border-bottom: 2px solid #334155; padding-bottom: 4px; }
  .summary { font-size: 10.5pt; color: #cbd5e1; }
  .exp-item { margin-bottom: 14px; }
  .exp-item:last-child { margin-bottom: 0; }
  .exp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .exp-title { font-weight: 700; font-size: 11pt; color: #f8fafc; }
  .exp-company { color: #94a3b8; font-size: 10pt; }
  .exp-dates { color: #64748b; font-size: 9pt; white-space: nowrap; }
  .bullets { margin-top: 6px; padding-left: 16px; }
  .bullets li { margin-bottom: 4px; line-height: 1.45; color: #e2e8f0; }
  .languages-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .language-item { display: flex; justify-content: space-between; align-items: center; font-size: 9.5pt; }
  .lang-level { padding: 2px 7px; border-radius: 999px; font-size: 7.5pt; }
  .lang-level-high { background: var(--accent); color: #0f172a; }
  .lang-level-medium { background: #334155; color: #e2e8f0; }
</style>
</head>
<body>
<div class="page">
  <aside class="sidebar">
    {{#if photoB64}}<img class="photo" src="{{photoB64}}" alt="" />{{else}}<div class="photo-placeholder">{{initials}}</div>{{/if}}

    <h2>{{uiLabels.contact}}</h2>
    <div class="contact-info">
      <span>{{email}}</span>
      <span>{{phone}}</span>
    </div>

    <h2>{{uiLabels.skills}}</h2>
    <ul>
      {{#each content.skills}}<li>{{this}}</li>{{/each}}
    </ul>

    {{#if content.languages}}
    <h2>{{uiLabels.languages}}</h2>
    <ul class="languages-list">
      {{#each content.languages}}
        <li class="language-item">
          <span>{{this.name}}</span>
          <span class="lang-level lang-level-{{this.level}}">{{lookup ../levelLabels this.level}}</span>
        </li>
      {{/each}}
    </ul>
    {{/if}}
  </aside>

  <main class="main">
    <h1>{{fullName}}</h1>
    {{#if roleTitle}}<div class="role-line">{{roleTitle}}</div>{{/if}}

    <section>
      <h3>{{uiLabels.summary}}</h3>
      <p class="summary">{{content.summary}}</p>
    </section>

    <section>
      <h3>{{uiLabels.experience}}</h3>
      {{#each content.experience}}
        <div class="exp-item">
          <div class="exp-head">
            <div>
              <div class="exp-title">{{title}}</div>
              <div class="exp-company">{{company}}</div>
            </div>
            <div class="exp-dates">{{startDate}} — {{endDate}}</div>
          </div>
          <ul class="bullets">
            {{#each bullets}}<li>{{this}}</li>{{/each}}
          </ul>
        </div>
      {{/each}}
    </section>
  </main>
</div>
</body>
</html>
