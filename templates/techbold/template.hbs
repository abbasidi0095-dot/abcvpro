<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root { --accent: {{accentColor}}; --font-scale: {{fontScale}}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  body { 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
    color: #0f172a; 
    line-height: 1.45; 
    font-size: calc(9.5pt * var(--font-scale)); 
    background-color: #fafafa;
  }
  
  .page { 
    min-height: 297mm; 
    width: 210mm; 
    padding: 15mm;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  /* Decorative futuristic corner grids */
  .page::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    width: 40px; height: 40px;
    border-top: 3px solid var(--accent);
    border-left: 3px solid var(--accent);
    pointer-events: none;
  }
  .page::after {
    content: "";
    position: absolute;
    bottom: 0; right: 0;
    width: 40px; height: 40px;
    border-bottom: 3px solid var(--accent);
    border-right: 3px solid var(--accent);
    pointer-events: none;
  }

  /* Technical terminal style header */
  .header {
    border: 1px solid #e2e8f0;
    border-left: 4px solid var(--accent);
    background-color: #ffffff;
    padding: 14px 18px;
    margin-bottom: 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .header-left { display: flex; align-items: center; gap: 14px; }
  
  .photo { 
    width: 60px; height: 60px; 
    object-fit: cover; 
    border-radius: 6px; 
    border: 2px solid var(--accent); 
  }
  
  .photo-placeholder { 
    width: 60px; height: 60px; 
    border-radius: 6px; 
    border: 2px solid var(--accent); 
    background-color: #f8fafc; 
    display: flex; align-items: center; justify-content: center; 
    font-size: 16px; font-weight: 700; color: var(--accent); 
  }

  .name-block h1 { 
    font-size: 18pt; 
    font-weight: 800; 
    text-transform: uppercase; 
    letter-spacing: -0.01em; 
    color: #0f172a;
    line-height: 1.1;
  }
  
  .name-block .role { 
    font-family: "Courier New", Courier, monospace;
    font-size: 8.5pt; 
    color: var(--accent); 
    font-weight: 700; 
    text-transform: uppercase;
    margin-top: 2px;
  }

  .contact-info { 
    text-align: right; 
    font-family: "Courier New", Courier, monospace;
    font-size: 8pt; 
    color: #475569;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* Main structure */
  .grid {
    display: flex;
    gap: 15px;
    flex: 1;
  }

  .col-main {
    flex: 2;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .col-sidebar {
    width: 180px;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  /* Universal Block aesthetics */
  .block {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    padding: 12px 14px;
  }

  .block-title {
    font-family: "Courier New", Courier, monospace;
    font-size: 9pt;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
    border-bottom: 1px dashed #e2e8f0;
    padding-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  
  .block-title::before {
    content: "■";
    font-size: 8.5pt;
  }

  /* Summary details */
  .summary-text {
    font-size: 9pt;
    color: #334155;
    text-align: justify;
  }

  /* Experience styles */
  .exp-timeline {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .exp-node {
    position: relative;
    padding-left: 10px;
    border-left: 2px solid var(--accent);
  }

  .exp-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2px;
  }

  .exp-role-company {
    font-size: 9.5pt;
    font-weight: 700;
    color: #0f172a;
  }
  
  .exp-company-highlight {
    color: var(--accent);
    font-weight: 600;
  }

  .exp-date {
    font-family: "Courier New", Courier, monospace;
    font-size: 8pt;
    font-weight: 700;
    color: #64748b;
    background-color: #f1f5f9;
    padding: 1px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }

  .exp-bullets {
    list-style: none;
    padding-left: 4px;
  }

  .exp-bullets li {
    font-size: 8.5pt;
    color: #334155;
    position: relative;
    padding-left: 10px;
    margin-bottom: 2px;
  }
  
  .exp-bullets li::before {
    content: "›";
    position: absolute;
    left: 0; top: 0;
    color: var(--accent);
    font-weight: 800;
  }

  /* Badge grids for skills */
  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .skill-badge {
    font-family: "Courier New", Courier, monospace;
    font-size: 7.5pt;
    font-weight: 700;
    background-color: #f8fafc;
    color: #334155;
    border: 1px solid #e2e8f0;
    padding: 2px 6px;
    border-radius: 3px;
    transition: background 0.2s;
  }

  .skill-badge:hover {
    background-color: var(--accent);
    color: #ffffff;
    border-color: var(--accent);
  }

  /* Languages */
  .languages {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lang-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 8.5pt;
  }

  .lang-name {
    font-weight: 600;
    color: #334155;
  }

  .lang-bar {
    width: 60px;
    height: 4px;
    background-color: #e2e8f0;
    border-radius: 2px;
    position: relative;
    overflow: hidden;
  }

  .lang-bar-fill {
    position: absolute;
    left: 0; top: 0;
    height: 100%;
    background-color: var(--accent);
    border-radius: 2px;
  }
  .lang-bar-fill.level-high { width: 100%; }
  .lang-bar-fill.level-medium { width: 60%; }
</style>
</head>
<body>
<div class="page">
  <div class="header">
    <div class="header-left">
      {{#if photoB64}}
        <img class="photo" src="{{photoB64}}" alt="" />
      {{else}}
        <div class="photo-placeholder">{{initials}}</div>
      {{/if}}
      <div class="name-block">
        <h1>{{fullName}}</h1>
        {{#if roleTitle}}<div class="role">{{roleTitle}}</div>{{/if}}
      </div>
    </div>
    <div class="contact-info">
      <div>EMAIL: {{email}}</div>
      {{#if phone}}<div>TEL: {{phone}}</div>{{/if}}
    </div>
  </div>

  <div class="grid">
    <div class="col-main">
      <div class="block">
        <div class="block-title">{{uiLabels.summary}}</div>
        <p class="summary-text">{{content.summary}}</p>
      </div>

      <div class="block" style="flex: 1;">
        <div class="block-title">{{uiLabels.experience}}</div>
        <div class="exp-timeline">
          {{#each content.experience}}
            <div class="exp-node">
              <div class="exp-head">
                <div class="exp-role-company">
                  <span>{{title}}</span>
                  <span class="exp-company-highlight"> @ {{company}}</span>
                </div>
                <div class="exp-date">{{startDate}} — {{endDate}}</div>
              </div>
              <ul class="exp-bullets">
                {{#each bullets}}<li>{{this}}</li>{{/each}}
              </ul>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    <div class="col-sidebar">
      <div class="block" style="flex: 1;">
        <div class="block-title">{{uiLabels.skills}}</div>
        <div class="skills-list">
          {{#each content.skills}}
            <span class="skill-badge">{{this}}</span>
          {{/each}}
        </div>
      </div>

      {{#if content.languages}}
      <div class="block">
        <div class="block-title">{{uiLabels.languages}}</div>
        <div class="languages">
          {{#each content.languages}}
            <div class="lang-row">
              <span class="lang-name">{{this.name}}</span>
              <div class="lang-bar">
                <div class="lang-bar-fill level-{{this.level}}"></div>
              </div>
            </div>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </div>
  </div>
</div>
</body>
</html>
