<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
  @page { margin: 0; size: A4; }
  :root {
    --accent: {{accentColor}};
    --font-scale: {{fontScale}};
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "Inter", -apple-system, "Segoe UI", Roboto, sans-serif; color: #1f2937; line-height: 1.5; font-size: calc(10.5pt * var(--font-scale)); }
  .page { display: flex; min-height: 297mm; width: 210mm; }
  .sidebar {
    width: 32%;
    background: var(--accent);
    color: #fff;
    padding: 18mm 10mm 10mm;
  }
  .main {
    flex: 1;
    padding: 18mm 12mm 10mm;
    background: #fff;
  }
  .photo {
    width: 110px;
    height: 146px;
    border-radius: 8px;
    object-fit: cover;
    margin-bottom: 22px;
    border: 4px solid rgba(255,255,255,0.4);
  }
  .photo-placeholder {
    width: 110px;
    height: 146px;
    border-radius: 8px;
    margin-bottom: 22px;
    background: rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    color: rgba(255,255,255,0.85);
  }
  .sidebar h2 {
    font-size: 9pt;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding-bottom: 6px;
    margin-bottom: 10px;
    border-bottom: 1px solid rgba(255,255,255,0.5);
    margin-top: 18px;
  }
  .sidebar h2:first-child { margin-top: 0; }
  .contact-row { display: flex; flex-direction: column; gap: 8px; word-break: break-word; }
  .contact-row span { font-size: 9.5pt; }
  .sidebar ul { list-style: none; display: flex; flex-wrap: wrap; gap: 6px; }
  .sidebar li {
    background: rgba(255,255,255,0.18);
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 9pt;
  }
  .main h1 { font-size: 26pt; font-weight: 700; letter-spacing: -0.02em; }
  .main .role-line { color: var(--accent); font-size: 12pt; margin-top: 2px; font-weight: 600; }
  .main section { margin-top: 22px; }
  .main h3 {
    font-size: 10.5pt;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
    margin-bottom: 10px;
    border-bottom: 2px solid var(--accent);
    padding-bottom: 4px;
  }
  .summary { font-size: 10.5pt; color: #374151; }
  .exp-item { margin-bottom: 14px; }
  .exp-item:last-child { margin-bottom: 0; }
  .exp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; }
  .exp-title { font-weight: 700; font-size: 11pt; }
  .exp-company { color: #4b5563; font-size: 10pt; }
  .exp-dates { color: #6b7280; font-size: 9pt; white-space: nowrap; }
  .exp-items { margin-top: 6px; padding-left: 16px; }
  .exp-items li { margin-bottom: 4px; line-height: 1.45; }
  .languages-list { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .language-item { display: flex; justify-content: space-between; align-items: center; font-size: 9.5pt; }
  .lang-level { padding: 2px 8px; border-radius: 999px; font-size: 8pt; }
  .lang-level-high { background: rgba(255,255,255,0.35); color: #fff; }
  .lang-level-medium { background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); }
</style>
</head>
<body>
<div class="page">
  <aside class="sidebar">
    {{#if photoB64}}
      <img class="photo" src="{{photoB64}}" alt="" />
    {{else}}
      <div class="photo-placeholder">{{initials}}</div>
    {{/if}}

    <h2>{{uiLabels.contact}}</h2>
    <div class="contact-row">
      <span>{{email}}</span>
      <span>{{phone}}</span>
    </div>

    <h2>{{uiLabels.skills}}</h2>
    <ul>
      {{#each content.skills}}
        <li>{{this}}</li>
      {{/each}}
    </ul>

    {{#if content.languages}}
    <h2>{{uiLabels.languages}}</h2>
    <ul class="languages-list">
      {{#each content.languages}}
        <li class="language-item">
          <span>{{this.name}}</span>
          <span class="lang-level lang-level-{{this.level}}">{{lookup ../levelLabels this.level}}</span>
        </li>
      {{/each}}
    </ul>
    {{/if}}
  </aside>

  <main class="main">
    <h1>{{fullName}}</h1>
    {{#if roleTitle}}<div class="role-line">{{roleTitle}}</div>{{/if}}

    <section>
      <h3>{{uiLabels.summary}}</h3>
      <p class="summary">{{content.summary}}</p>
    </section>

    <section>
      <h3>{{uiLabels.experience}}</h3>
      {{#each content.experience}}
        <div class="exp-item">
          <div class="exp-head">
            <div>
              <div class="exp-title">{{title}}</div>
              <div class="exp-company">{{company}}</div>
            </div>
            <div class="exp-dates">{{startDate}} — {{endDate}}</div>
          </div>
          <ul class="exp-items">
            {{#each bullets}}
              <li>{{this}}</li>
            {{/each}}
          </ul>
        </div>
      {{/each}}
    </section>
  </main>
</div>
</body>
</html>